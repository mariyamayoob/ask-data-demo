# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-01

# Database Configuration
DATABASE_TYPE=mysql
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=myuser
DATABASE_PASSWORD=mypass
DATABASE_NAME=mydatabase

# Application Configuration
SCHEMA_METADATA_PATH=data/schema_metadata.json
MAX_SELECTED_TABLES=4
ENABLE_SQL_VALIDATION=true
QUERY_TIMEOUT_SECONDS=30

# Model Configuration
TABLE_SELECTION_MODEL=gpt-4
SQL_GENERATION_MODEL=gpt-4
MAX_TOKENS_TABLE_SELECTION=100
MAX_TOKENS_SQL_GENERATION=1000

# API Configuration
API_HOST=0.0.0.0
API_PORT=8015
DEBUG_MODE=false

# Security Configuration (adjust for production)
ALLOWED_ORIGINS=["*"] 
# API_KEY_HEADER=X-API-Key  # Uncomment if you want API key authentication

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

